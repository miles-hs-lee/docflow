NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
NEXT_PUBLIC_APP_URL=http://localhost:3000
VIEWER_COOKIE_SECRET=replace-with-long-random-secret
AUTOMATION_CRON_SECRET=replace-with-long-random-secret

# Local-only: GitHub Personal Access Token used by `npm run push`
# (and by Claude when asked to push). Needs `repo` scope on
# miles-hs-lee/docflow. Never commit a real value — .env.local is
# gitignored. The token is read from the environment, never written
# to any file the dev server ships to the browser.
GITHUB_TOKEN=ghp_REPLACE_WITH_YOUR_PAT
