NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
NEXT_PUBLIC_APP_URL=http://localhost:3000
VIEWER_COOKIE_SECRET=replace-with-long-random-secret
AUTOMATION_CRON_SECRET=replace-with-long-random-secret
# Optional: dedicated salt for HMAC-hashing viewer IP addresses in link_events.
# If unset, hashIp() falls back to VIEWER_COOKIE_SECRET. In production, set
# this independently so rotating one secret does not invalidate the other.
IP_HASH_SALT=replace-with-long-random-secret

# Upstash Redis (REST). From the Upstash console → your database →
# "REST API" tab → copy the .env snippet. Used for rate limiting, the
# claim_view dedup cache, and (later) the session store. Both required
# together; features degrade or fail loudly when unset (see lib/redis.ts).
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_REST_TOKEN

# Local-only: GitHub Personal Access Token used by `npm run push`
# (and by Claude when asked to push). Needs `repo` scope on
# miles-hs-lee/docflow. Never commit a real value — .env.local is
# gitignored. The token is read from the environment, never written
# to any file the dev server ships to the browser.
GITHUB_TOKEN=ghp_REPLACE_WITH_YOUR_PAT
