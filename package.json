{
  "name": "docflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:polaris": "eslint app components --config eslint.polaris.config.mjs --max-warnings=0",
    "check:supabase-auth": "node scripts/check-supabase-auth.mjs",
    "check:redis": "node scripts/check-redis.mjs",
    "check:qstash": "node scripts/check-qstash.mjs",
    "postinstall": "node -e \"const path=require('node:path');const reactPdfDir=path.dirname(require.resolve('react-pdf/package.json'));const worker=require.resolve('pdfjs-dist/build/pdf.worker.min.mjs',{paths:[reactPdfDir]});require('node:fs').copyFileSync(worker,'public/pdf.worker.min.mjs')\""
  },
  "dependencies": {
    "@polaris/ui": "https://github.com/PolarisOffice/PolarisDesign/releases/download/v0.8.0-rc.9/polaris-ui-0.8.0-rc.9.tgz",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.0",
    "@upstash/qstash": "^2.11.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "echarts": "^6.1.0",
    "next": "^15.5.18",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-pdf": "^10.4.1",
    "topojson-client": "^3.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@polaris/lint": "https://github.com/PolarisOffice/PolarisDesign/releases/download/v0.8.0-rc.8/polaris-lint-0.8.0-rc.8.tgz",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/topojson-client": "^3.1.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.20.1",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "postcss": "$postcss",
    "picomatch": "^4.0.3"
  }
}
