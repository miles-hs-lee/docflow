    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "next": "^15.5.18",
    "pdfjs-dist": "^5.7.284",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-pdf": "^10.4.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@polaris/lint": "https://github.com/PolarisOffice/PolarisDesign/releases/download/v0.7.3/polaris-lint-0.7.3.tgz",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.5",
